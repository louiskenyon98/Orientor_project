Resources:
  AWSEBAutoScalingGroup:
    Metadata:
      AWS::CloudFormation::Authentication:
        S3Auth:
          type: S3
          buckets: ["navigo-finetune-embedder-prod"]
          roleName: aws-elasticbeanstalk-ec2-role
  
  # Modify the EC2 instance profile to ensure it has S3 read access
  S3AccessInstanceProfile:
    Type: AWS::IAM::InstanceProfile
    Properties:
      Path: "/"
      Roles: ["aws-elasticbeanstalk-ec2-role"]

  # Ensure the EC2 role has proper S3 access
  S3AccessPolicy:
    Type: AWS::IAM::Policy
    Properties:
      PolicyName: "NavigoS3ModelAccess"
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: "Allow"
            Action:
              - "s3:GetObject"
              - "s3:ListBucket"
            Resource:
              - "arn:aws:s3:::navigo-finetune-embedder-prod"
              - "arn:aws:s3:::navigo-finetune-embedder-prod/*"
      Roles: ["aws-elasticbeanstalk-ec2-role"]

option_settings:
  # Increase deployment timeout to allow for model downloads
  aws:elasticbeanstalk:command:
    Timeout: 1800  # 30 minutes timeout

  # Configure CloudWatch logs
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7

  # Set environment type and instance
  aws:elasticbeanstalk:environment:
    EnvironmentType: LoadBalanced
    ServiceRole: aws-elasticbeanstalk-service-role

files:
  "/etc/collectd/collectd.conf.d/custom.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      LoadPlugin processes
      <Plugin processes>
        ProcessMatch "uvicorn" ".*uvicorn.*"
        ProcessMatch "python" ".*python.*"
      </Plugin>

packages:
  yum:
    jq: []
    awslogs: [] 